# Copy to `.env` only if you need to override the API location.
#
# Local dev: leave blank. Vite proxies /api → the backend (see vite.config.js).
#
# Production (Vercel): set to your deployed backend URL INCLUDING /api, e.g.
#   VITE_API_URL=https://e41c-api.up.railway.app/api
# Vite inlines this at build time, so set it in the Vercel project settings.
VITE_API_URL=
