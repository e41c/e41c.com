# Copy to `.env` and fill in. The .env file is gitignored.

PORT=4000

# Postgres connection string.
# Local dev (with `npm run db:up`) — this default matches docker-compose.yml:
DATABASE_URL=postgres://e41c:e41c@localhost:5432/e41c
# Production — paste your Neon connection string here instead.

# Neon and most managed Postgres require SSL → set "true" in production.
# Local Docker Postgres does not → keep "false" for dev.
DATABASE_SSL=false

# Allowed frontend origin(s) in production, comma-separated, e.g.
#   CORS_ORIGIN=https://e41c.com,https://www.e41c.com
# Leave blank in dev to allow all origins.
CORS_ORIGIN=

# Optional — used by GET /api/github/repos to show live repo stats.
# Leave blank and the endpoint returns an empty list.
GITHUB_USERNAME=
# Optional read-only token: raises the GitHub rate limit 60/hr → 5000/hr.
GITHUB_TOKEN=
