{
  "name": "e41c",
  "private": true,
  "version": "0.1.0",
  "description": "Personal site of Eric Grigor — e41c.com",
  "type": "module",
  "workspaces": [
    "frontend",
    "backend"
  ],
  "scripts": {
    "dev": "concurrently -n api,web -c blue,magenta \"npm:dev:api\" \"npm:dev:web\"",
    "dev:api": "npm run dev --workspace backend",
    "dev:web": "npm run dev --workspace frontend",
    "build": "npm run build --workspace frontend",
    "seed": "npm run seed --workspace backend",
    "db:up": "docker compose up -d db",
    "db:down": "docker compose down",
    "db:reset": "docker compose down -v && docker compose up -d db",
    "db:logs": "docker compose logs -f db"
  },
  "devDependencies": {
    "concurrently": "^9.1.0"
  }
}
